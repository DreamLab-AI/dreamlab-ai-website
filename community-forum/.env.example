# ===========================================
# DreamLab Community Forum
# Cloudflare Workers Architecture
# ===========================================

# ===========================================
# NOSTR RELAY CONFIGURATION
# ===========================================
# Cloudflare Workers relay (D1 + Durable Objects)
VITE_RELAY_URL=wss://dreamlab-nostr-relay.solitary-paper-764d.workers.dev

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
# Admin public key in HEX format (64 characters, NOT npub)
VITE_ADMIN_PUBKEY=

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
VITE_APP_NAME=DreamLab Community
VITE_APP_VERSION=0.1.0
VITE_NDK_DEBUG=false

# ===========================================
# CLOUDFLARE WORKER APIs
# ===========================================
# Auth API — WebAuthn registration/authentication, NIP-98, pod provisioning
VITE_AUTH_API_URL=https://dreamlab-auth-api.solitary-paper-764d.workers.dev

# Pod API — Solid pods, R2 storage, WAC ACL, images/media
VITE_POD_API_URL=https://dreamlab-pod-api.solitary-paper-764d.workers.dev

# Search API — RuVector WASM, .rvf in R2, embeddings
VITE_SEARCH_API_URL=https://dreamlab-search-api.solitary-paper-764d.workers.dev

# Link Preview API — OG metadata fetching, Twitter oEmbed
VITE_LINK_PREVIEW_API_URL=https://dreamlab-link-preview.solitary-paper-764d.workers.dev

# ===========================================
# AGENT CONFIGURATION
# ===========================================
# Public relay for VisionFlow agent DM routing
VITE_AGENT_RELAY_URL=wss://relay.damus.io

# ===========================================
# IMAGE ENCRYPTION
# ===========================================
# Enable client-side AES-256-GCM encryption for images in private channels/DMs
VITE_IMAGE_ENCRYPTION_ENABLED=true

# ===========================================
# WASM CRYPTO ACCELERATION
# ===========================================
# Enable Rust WASM crypto (nostr-core-wasm) for accelerated Schnorr/HKDF/NIP-44
# Set to 'true' to use WASM, omit or set to anything else for JS fallback
VITE_USE_WASM_CRYPTO=true

# ===========================================
# DEVELOPMENT MODE (LOCAL ONLY)
# ===========================================
# Dev login buttons only appear when BOTH conditions are met:
#   1. Running in Vite dev server OR ?dev URL parameter
#   2. At least one of these credentials is set
# VITE_DEV_ADMIN_NSEC=nsec1...
# VITE_DEV_ADMIN_SEED=word1 word2 word3 ... word12
