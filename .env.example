# Supabase Configuration
# Get these values from your Supabase project settings
# Dashboard: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe to expose in client-side code)
# This key has Row Level Security (RLS) enabled
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Auth API (WebAuthn + NIP-98 server on Cloudflare Workers)
VITE_AUTH_API_URL=https://dreamlab-auth-api.solitary-paper-764d.workers.dev

# Pod API (Solid Pod CRUD + /pay/ payment routes on Cloudflare Workers)
VITE_POD_API_URL=https://dreamlab-pod-api.solitary-paper-764d.workers.dev

# Search API (full-text + vector search on Cloudflare Workers)
VITE_SEARCH_API_URL=https://dreamlab-search-api.solitary-paper-764d.workers.dev

# Link-preview API (OG/social card unfurling on Cloudflare Workers)
VITE_LINK_PREVIEW_API_URL=https://dreamlab-link-preview.solitary-paper-764d.workers.dev

# Nostr relay (WebSocket). The contact form and the Talk-to-AI chat publish
# gift-wrapped DMs here; the forum/BBS clients also read it from window.__ENV__.
VITE_RELAY_URL=wss://dreamlab-nostr-relay.solitary-paper-764d.workers.dev

# Nostr DM recipients (hex pubkeys, public identifiers — not secrets).
# Canonical source: forum-config/dreamlab.toml (kept in sync by hand, ADR-037).
# Signup-DM recipient (ADR-041). INTERIM: the operator's current working admin
# key (visionclaw-server, dreamlab.toml:57, already relay-whitelisted). The
# ADR-040 D3 key-split runbook must re-point this when the operator key is minted.
VITE_ADMIN_PUBKEY=11ed64225dd5e2c5e18f61ad43d5ad9272d08739d3a20dd25886197b0738663c
# junkiejarvis (conversational agent) — receives Talk-to-AI chat DMs (ADR-042).
VITE_JARVIS_PUBKEY=2de44d5622eef79519ac078f6e227a85aecbaefd561e4e50c5f51dfadbf916e9

# SECURITY NOTES:
# - Never commit .env files with real credentials to git
# - The ANON key is designed to be public but should still use RLS policies
# - Never use the SERVICE_ROLE key in client-side code
# - Rotate keys if they are accidentally exposed
